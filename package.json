{
  "name": "astro-drift",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "check:ci": "npm run lint && npm run typecheck:tests && npm test && npm run test:e2e",
    "check": "npm run check:ci && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
